{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "node_modules/",
    ".engin/",
    "wwwroot/",
    "bin/",
    "obj/",
    "dist/",
    "SampleFiles/",
    "coverage/",
    "package-lock.json"
  ],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-console": "off"
  }
}
